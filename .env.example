# CDUS Environment Configuration

# --- Agent Configuration ---
# Port for the agent's P2P listener
CDUS_PORT=5200
# Path to the local socket for IPC (UI communication)
CDUS_AGENT_SOCKET=/tmp/cdus-agent.sock
# Directory where the agent stores its identity and databases
# CDUS_DATA_DIR=~/.local/share/cdus-agent
# URL of the relay server for remote discovery and fallback
CDUS_RELAY_URL=http://localhost:8080

# --- Relay Server Configuration ---
# Port for the relay server to listen on
PORT=8080
# Secret for Coturn REST API authentication (must match Coturn config)
TURN_SECRET=v1-default-secret-replace-me
# URL of the TURN server (e.g., turn:your-domain.com:3478)
TURN_URL=turn:localhost:3478

# --- GUI / Frontend Configuration ---
# Host for the Tauri development server
TAURI_DEV_HOST=localhost
# Port for the Tauri GUI
GUI_PORT=1420
